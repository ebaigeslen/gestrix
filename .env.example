# Gestrix environment configuration.
# Copy to .env and fill in real values. .env is gitignored.

# --- App ---
APP_NAME=gestrix-seo
APP_VERSION=0.1.0
ENV=dev

# --- Database ---
DATABASE_URL=sqlite:///./data/gestrix.db
DATA_DIR=./data

# --- Auth / JWT ---
# REQUIRED outside tests. Generate one, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ALGORITHM=HS256
# Session lifetime in minutes (default 7 days).
JWT_EXPIRY_MINUTES=10080
# Session cookie settings.
COOKIE_NAME=gestrix_session
# Set COOKIE_SECURE=true in production (HTTPS only).
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- LLM (used in later tickets) ---
OPENROUTER_API_KEY=

# --- Optional integrations (later tickets) ---
TAVILY_API_KEY=
LOGFIRE_TOKEN=
